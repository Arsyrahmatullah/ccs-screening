# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# Raw/processed data folders (user-specific downloads & derived outputs -
# keep these local, never commit third-party data or run-specific results)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# DO NOT block data/external/: it contains the shipped sample/illustrative
# fallback data that every notebook needs to run out-of-the-box.

# Figures ARE committed intentionally: every figure this repo generates has
# its data source (real vs. illustrative/synthetic) printed directly in its
# title, so there is no risk of a misleading result being displayed silently.

# OS / editor
.DS_Store
.vscode/
.idea/

# Jupyter
*.ipynb_checkpoints